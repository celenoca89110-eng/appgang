# Copie ce fichier en ".env" et adapte les valeurs

# Port d'ecoute du serveur
PORT=3000

# Secret utilise pour signer les tokens JWT - CHANGE CETTE VALEUR EN PRODUCTION
JWT_SECRET=change-moi-en-une-longue-chaine-aleatoire-et-secrete

# Duree de validite des tokens (format: 1h, 12h, 7d, ...)
JWT_EXPIRES_IN=12h

# Chaine de connexion PostgreSQL.
# - En local (Postgres installe ou via Docker) :
#   postgres://postgres:postgres@localhost:5432/gangapp
# - Sur Render : collez l' "Internal Database URL" fournie par votre service
#   PostgreSQL Render (Dashboard -> votre base -> Connect -> Internal Database URL).
#   Si vous deployez via render.yaml fourni dans ce projet, cette variable est
#   injectee automatiquement et vous n'avez pas besoin de la definir ici.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gangapp

# Nombre max de connexions simultanees dans le pool (facultatif)
PG_POOL_MAX=10

# Identifiants du compte admin cree automatiquement au premier lancement
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeMoi123!
